cat > .gitignore << 'EOF'
# Data — too large for git
data/
output/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.python-version

# Virtual environments
venv/
.venv/
env/

# Environment variables
.env
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Distribution
dist/
build/
*.egg-info/
EOF